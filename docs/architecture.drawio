        <mxCell id="e-vision-prov" style="endArrow=classic;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeWidth=1;strokeColor=#6c8ebf;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="ing-vision" target="prov-gemini">
          <mxGeometry relative="1" as="geometry">

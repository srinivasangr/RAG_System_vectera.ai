        <!-- Embed step → Gemini provider -->
        <mxCell id="e-ing-embed-prov" style="endArrow=classic;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeWidth=1;strokeColor=#6c8ebf;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="ing-embed" target="prov-gemini">

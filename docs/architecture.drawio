              <mxPoint x="1250" y="560" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-embed-sf-label" value="upsert (idempotent by checksum)" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#1c6ea4" vertex="1" parent="1">
          <mxGeometry x="1250" y="560" width="190" height="20" as="geometry" />
        </mxCell>

        <!-- Vision → chunk_images -->
        <mxCell id="e-vision-images" style="endArrow=classic;html=1;rounded=0;dashed=1;dashPattern=8 4;strokeWidth=1;strokeColor=#1c6ea4;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="ing-vision" target="sf-images">
          <mxGeometry relative="1" as="geometry">

        <mxCell id="e-llm-log-label" value="log every query" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#1c6ea4" vertex="1" parent="1">
          <mxGeometry x="1100" y="540" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Answer back to UI -->
        <mxCell id="e-svc-ui" style="endArrow=classic;html=1;rounded=0;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.25;entryY=1;entryDx=0;entryDy=0;strokeWidth=2" edge="1" parent="1" source="query-group" target="ui-group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-svc-ui-label" value="Answer + Citations" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontColor=#333333" vertex="1" parent="1">
          <mxGeometry x="700" y="335" width="120" height="20" as="geometry" />
        </mxCell>

        <!-- chunk_images → UI -->
        <mxCell id="e-images-ui" style="endArrow=classic;html=1;rounded=0;strokeWidth=1;strokeColor=#1c6ea4;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="sf-images" target="ui-debug">

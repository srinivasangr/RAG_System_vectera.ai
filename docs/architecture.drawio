              <mxPoint x="1290" y="540" />
              <mxPoint x="1420" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- LLM step → query_log -->
        <mxCell id="e-llm-log" style="endArrow=classic;html=1;rounded=0;strokeWidth=1;strokeColor=#1c6ea4;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="step-llm" target="sf-log">
          <mxGeometry relative="1" as="geometry">

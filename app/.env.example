# =====================================================================
# RAG System — environment configuration
# Copy this file to `.env` and fill in your values. DO NOT COMMIT .env
# =====================================================================

# ---------------------------------------------------------------------
# Snowflake (required)
# ---------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=xxxxx-xxxxx          # e.g. ab12345.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=RAG_WH
SNOWFLAKE_DATABASE=RAG_DB
SNOWFLAKE_SCHEMA=RAG_SCHEMA

# ---------------------------------------------------------------------
# Provider selection (used by the app at runtime; can be overridden in UI)
# ---------------------------------------------------------------------
# LLM provider: openai | anthropic | gemini | cerebras | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Embedding provider:
#   local  - sentence-transformers (RECOMMENDED — no rate limits, no API key)
#   gemini - gemini-embedding-001 (hits free-tier 100 RPM limit easily)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# ---------------------------------------------------------------------
# Provider API keys — set the ones you plan to use
# ---------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------
# Retrieval tuning
# ---------------------------------------------------------------------
RETRIEVAL_TOP_K=8
RETRIEVAL_CANDIDATE_K=30
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# ---------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------
DOCUMENTS_DIR=../Documents
